{
  "name": "angelo-coelho-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-images": "node generate-images.js",
    "update:resume": "git submodule update --init --remote resume || true",
    "build:resume": "node scripts/build-resume.js",
    "prebuild": "npm run generate-images && npm run update:resume && npm run build:resume",
    "build": "npm run prebuild && tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
